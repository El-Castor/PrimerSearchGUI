# Primersearch GUI container settings.
# Edit values on the right side. Use quotes if a path has spaces.

# Docker image name and platform (Apple Silicon uses linux/amd64).
IMAGE_NAME=primersearch-gui
PLATFORM=linux/amd64

# Shiny upload limit in MB (large genomes may need 2048 or more).
SHINY_MAX_UPLOAD_MB=2048

# Optional genome directory to mount (leave empty to skip).
# Example:
# GENOMES_DIR="/path/to/GENOMES"
GENOMES_DIR=

# Where the genomes will appear inside the container.
# Use /data/GENOMES (recommended) or keep the original /Users/... path.
GENOMES_MOUNT=/data/GENOMES
